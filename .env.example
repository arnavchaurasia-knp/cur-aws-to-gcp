PORT=8080
DATA_DIR=/var/data/cur-web
SKILL_DIR=/home/ubuntu/.claude/skills/aws-gcp-cost-projection
# ANTHROPIC_API_KEY is read from the host environment (set VM-wide on prod;
# shell or system on dev). cur-web does not parse it — the spawned claude
# subprocess inherits it via os.Environ().
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://cur.facets.cloud/api/auth/callback
SESSION_SECRET=32-random-bytes-hex-encoded
RESEND_API_KEY=re_...
RESEND_FROM=Facets <noreply@facets.cloud>
APP_BASE_URL=https://cur.facets.cloud
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Local development only ---
# When DEV_AUTH_BYPASS=true:
#   - Google/Resend/Slack env vars are not required
#   - /api/auth/login sets a fake dev@google.com session immediately
#   - Cookies are non-Secure if APP_BASE_URL is http://
# DO NOT enable in production.
# DEV_AUTH_BYPASS=true
