PORT=8080
DATA_DIR=/var/data/cur-web
# ANTIGRAVITY_API_KEY is read from the host environment (set VM-wide on prod;
# shell or system on dev). cur-web does not parse it — the spawned agy
# subprocess inherits it via os.Environ(). GEMINI_API_KEY is ignored by agy.
ANTIGRAVITY_API_KEY=AQ....
AGY_MODEL=gemini-3.5-flash
# SKILL_DIR overrides the default skill lookup path (~/.gemini/.../skills/aws-gcp-cost-projection-gemini).
# Set this in the systemd unit or shell if the skill is installed to a non-standard location.
# SKILL_DIR=/path/to/skill/aws-gcp-cost-projection
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://cur.facets.cloud/api/auth/callback
SESSION_SECRET=<base64-encoded 32-byte random value — generate with: openssl rand -base64 32>
RESEND_API_KEY=re_...
RESEND_FROM=Facets <noreply@facets.cloud>
APP_BASE_URL=https://cur.facets.cloud
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ALLOWED_DOMAINS: comma-separated Google Workspace domains allowed to log in.
# Defaults to "google.com,facets.cloud" if unset. Add your domain here if different.
# ALLOWED_DOMAINS=facets.cloud,yourdomain.com

# ADMIN_EMAILS: comma-separated emails that can see all jobs via /admin.
# Leave unset to disable admin access entirely.
# ADMIN_EMAILS=you@facets.cloud

# LOG_LEVEL=debug enables verbose structured logging (default: info).
# LOG_FORMAT=text switches from JSON to human-readable logs for local dev.
# LOG_LEVEL=debug
# LOG_FORMAT=text

# --- Local development only ---
# When DEV_AUTH_BYPASS=true:
#   - Google/Resend/Slack env vars are not required
#   - /api/auth/login sets a fake dev@google.com session immediately
#   - Cookies are non-Secure if APP_BASE_URL is http://
# DO NOT enable in production.
# DEV_AUTH_BYPASS=true
